# Keep local development and verification state outside the repository and the
# user's real XDG directories. The path-resolution tests intentionally override
# these variables when they need to exercise precedence.
export XDG_DATA_HOME="\${TMPDIR:-/tmp}/asobi-xdg-\${USER:-user}"
export UV_CACHE_DIR="\${TMPDIR:-/tmp}/asobi-uv-cache-\${USER:-user}"
unset ASOBI_HOME
unset ASOBI_DATABASE_URL
unset ASOBI_TOPICS_DIR
